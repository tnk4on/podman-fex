=== H05: Code cache env = 1 ===
mode=grep
$ podman --connection test run --rm --platform linux/amd64 alpine sh -c 'printenv FEX_ENABLECODECACHINGWIP 2>/dev/null'
1
exit_code=0


═══ Phase 4: Environment Variables (env) ═══
=== E02: Code cache disabled (env override) ===
mode=fn
$ podman --connection test run --rm --platform linux/amd64 -e FEX_ENABLECODECACHINGWIP=0 docker.io/library/alpine:latest sh -c 'echo $FEX_ENABLECODECACHINGWIP'
0
exit_code=0

=== E11: OCI hook: FEX_APP_DATA_LOCATION ===
mode=fn
$ podman --connection test run --rm --platform linux/amd64 docker.io/library/alpine:latest sh -c 'echo $FEX_APP_DATA_LOCATION'
/tmp/fex-data/
exit_code=0

