
═══ Phase 1: Infrastructure (infra) ═══
=== INF01: OS info ===
mode=ssh
$ ssh: cat /etc/os-release | grep PRETTY_NAME
PRETTY_NAME="Fedora CoreOS 43.20260316.3.1"
exit_code=0

=== INF03: FEXInterpreter installed ===
mode=ssh
$ ssh: which FEXInterpreter 2>/dev/null && echo FOUND || echo MISSING
/usr/bin/FEXInterpreter
FOUND
exit_code=0

=== INF05: FEX RootFS found ===
mode=ssh
$ ssh: ls -d /usr/share/fex-emu/RootFS* 2>/dev/null || ls -d /var/lib/fex-emu* 2>/dev/null || echo MISSING
/usr/share/fex-emu/RootFS
exit_code=0

=== INF06: Virtualization type = vm-other ===
mode=ssh
$ ssh: systemd-detect-virt
vm-other
exit_code=0

=== INF07: binfmt handler registered ===
mode=ssh
$ ssh: ls /proc/sys/fs/binfmt_misc/ | grep -iE 'fex|x86_64' || echo NONE
FEX-x86
FEX-x86_64
exit_code=0

